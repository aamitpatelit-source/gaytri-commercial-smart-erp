{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "types": [
      "node"
    ],
    "lib": [
      "es2022"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*"
  ]
}